{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "flag_hash": {
      "type": "string"
    },
    "difficulty_estimate": {
      "type": "string",
      "enum": ["rookie", "easy", "medium", "hard"]
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "authors": {
      "type": "array",
      "description": "People credited as task authors, optionally with a contact or profile URL.",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "url": {
            "type": "string",
            "format": "uri"
          }
        },
        "required": ["name"]
      }
    },
    "task_release_phase": {
      "type": "string",
      "description": "A phase name used in event.yaml"
    },
    "assets": {
      "type": "array",
      "items": {
          "type": "object",
          "properties": {
            "description": {
                "type": "string"
            },
            "path": {
                "type": "string"
            }
          },
          "required": ["description", "path"]
      }
    },
    "display": {
      "type": "object",
      "properties": {
        "icon_coordinates": {
          "type": "object",
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          },
          "required": ["x", "y"]
        }
      },
      "required": ["icon_coordinates"]
    },
    "deployment": {
      "type": "object",
      "properties": {
        "targets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "description": "Restrict this task to only deploy on these targets. If omitted, task deploys on all targets."
        }
      },
      "required": ["targets"]
    }
  },
  "required": ["id", "name", "flag_hash", "difficulty_estimate", "labels", "display"]
}
