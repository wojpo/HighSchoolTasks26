# Docker socket path used by Traefik in the main dev stack.
# Copy this file to .env and adjust for your setup.

# Rootless Docker (replace 1000 with your UID, or run: echo $UID)
# DOCKER_SOCK=/run/user/1000/docker.sock

# Rootful Docker (default if DOCKER_SOCK is unset)
# DOCKER_SOCK=/var/run/docker.sock

# Podman socket (rootless)
# DOCKER_SOCK=/run/user/1000/podman/podman.sock

# Tasks URL required for e2e tests pointing to your production IP / url
# TASKS_DEPLOYMENT_URL=http://localhost:8080
